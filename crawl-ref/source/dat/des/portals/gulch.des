##############################################################################
#
# The Gulch (by regret-index).
#
# An experimental hard-mode Sewer much later than Sewers (in fact, so late and
# so disconnected both can spawn in the same game). Unlike those sewers mostly
# just deploying pests and rogues in wet tunnels and caverns, this focuses in on
# mutant animals, abandoned constructs and experiments, and various borrowed
# beasts. It also mixes those with fruiting mould patches and fields of metal
# scrap, with fairly less (but still some) water than those sewers.
#
# Most notably, it comes with inflicting three transient mutations as soon as
# you enter the portal, though none when exiting it. While this deploys its own
# set of completely unique monsters much like Desolation, it's unlikely to end
# up in any proper Crypt roulette set-up (autoexplore would need to handle
# firewood better), but some notes have been left for some potential future.
# See c33ae53 and b4834b1 for further details and intents.
#
# <<1>>     Gulch layout subvault functions
# <<2>>     Gulch entry vaults
# <<3>>     Gulch layout vaults and subvaults
# <<4>>     Gulch planning area
##############################################################################

: crawl_require('dlua/vault.lua')

{{
function gulch_portal(e, shallow, deep)
  local timeout_turns = crawl.random_range(600, 800)

  local messager =
    timed_msg {
       initmsg = { "You hear the sound of rushing sludge.",
                   "There is an entrance to a gutter gulch on this level. "
                   .. "Hurry and find it before the portal rusts away!" },
      finalmsg = "You hear the drain falling apart.",

      verb = 'rusting',
      noisemaker = 'mutagenic drain',
      ranges = {
        { 5000, 'slow ' },  { 4000, '' },
        { 2500, 'brisk ' }, { 1500, 'quick ' },
        { 0, 'rapid ' }
      }
    }

  e.lua_marker('O',
      timed_marker {
        disappear = "The mutagenic drain falls to bits.",
        entity = 'drain',
        turns = timeout_turns,
        single_timed = true,
        floor = "expired_portal",
        feat_tile = "dngn_portal_gulch_gone",
        msg = messager })
  e.tags("uniq_gulch vaults_gulch no_monster_gen chance_gulch no_pool_fixup")
  -- We use the Vaults room generator to places these.
  e.chance(0)
  e.kfeat("O = enter_gulch")
  e.kfeat(shallow .. "y = W")
  e.kfeat("z = v")
  e.colour(shallow .. " = lightgreen")
  e.colour(deep .. " = green")
  e.ftile("O = floor_gulch_trash")
  e.tile("z = metal_wall_gulch")
end

-- Gulches can have three different terrain and boss themes. By default:
-- 60%: Heavy mould patches, additional fungi, and sewage sovereigns.
-- 30%: Many stacks of scrap and a scrapshell chimera.
-- 10%: Extra deep water and either slymdra or amoebas.
function gulch_boss_theme_sets(e, even_odds)
  if (even_odds and crawl.one_chance_in(3)) or crawl.x_chance_in_y(3, 5) then
    e.kmons("0 = mongrel wurm / roaming sludgefish w:8 / " ..
                "crawling flesh cage w:2")
    e.kmons("6 = sewage sovereign band")
    e.kmons("'? = fungus")
    e.kfeat("? = mould_patch")
    e.nsubst("6 = 1:6 / 1:; / *:0")
    e.nsubst("0 = 1:; / 1:0; / *:0")
  elseif (even_odds and crawl.coinflip()) or crawl.x_chance_in_y(3, 4) then
    e.kmons("0 = rusted inspector / fungal shambler / " ..
                "telencephalon w:4 / crawling flesh cage w:2")
    e.kmons("6 = scrapshell chimera")
    e.kmons("? = stack of scrap")
    e.subst("' = ;;?")
    e.nsubst("6 = 1:6 / 1:600 / *:0")
    e.nsubst("0 = 1:` / 1:0; / *:0")
  else
    e.kmons("0 = slime creature / telencephalon w:2")
    e.kmons("6 = three-headed slymdra / four-headed slymdra / " ..
                "colossal amoeba w:20")
    e.kmons("7 = formless jellyfish")
    e.subst("0 = 22335")
    e.nsubst("6 = 1:6 / 1:700 / *:0")
    e.subst("' = w")
    e.subst("? = W")
  end
end

function gulch_setup(e, main_vault, trap_count)
  e.kfeat("^ = trap_tyrant w:20 / trap_dispersal w:4 / " ..
              "trap_harlequin w:2 / trap_zot w:2")
  e.kfeat("< = exit_gulch")
  e.kfeat("} = purified_mutation_catalyst")
  e.subst("^ : ^.")
  e.nsubst("^ = " .. trap_count .. ":^ / 1:^. / *:.")
  decorative_floor(e, ']', "empty mutation catalyst")
  if main_vault then
    e.place("Gulch")
    e.tags("no_monster_gen no_item_gen no_pool_fixup")
    e.orient("encompass")
  end
  e.colour("w = green")
  e.colour("W = lightgreen")
  e.ftile("`0123456 = floor_gulch / floor_gulch_trash")
  e.ftile("|;?$ = floor_gulch_trash")
  e.ftile("} = floor_gulch_catalyst")
  e.tile("c = wall_stone_gulch")
  e.tile("v = metal_wall_gulch")
end

-- Gulch loot uses the standard defghijk item glyphs to focus on poison, acid,
-- and Forgecraft rewards. It always provides the following:
--  * Two top-tier venom-branded weapons / good_item hand cannons
--  * Two Alchemy, Hexes, or Forgecraft magic-enhancing items
--  * A rPois / rCorr / prior schools / flying piece of armour / jewellery
--  * Two random tier 3 or 4 talisman randarts with rPois / rCorr
-- To fit both the trash themes and to help people who didn't bring in
-- flaming weapons for the ~5% of encountering slymdra, there's also a bunch
-- of damaged ego weapons, including flaming ones available via cross-training
-- for all characters. Purified mutation catalysts- single use good mutation
-- features- are set up in gulch_setup instead.
function gulch_loot(e, item_nsubst, potion_count)
  local weapon = {"quick blade w:6", "great mace w:4", "eveningstar w:6",
                  "double sword w:5", "triple sword w:5", "broad axe w:4",
                  "executioner's axe w:6", "partisan w:4", "bardiche w:6",
                  "lajatang w:6"}
  local schools1 = util.random_from({"alchemy", "hexes", "forgecraft"})
  local schools2 = util.random_from({"fire", "ice", "air", "earth"})
  local orbprop = util.random_from({"Alch", "Forge", "rPois", "rCorr"})
  local weapon_string = ""
  for _, wt in ipairs(weapon) do
    weapon_string = weapon_string .. " / " .. wt .. " ego:venom pre_id good_item"
  end
  local n_weapon = string.gsub(weapon_string, "%s*/$", "")
  local res_p = "ego:poison_resistance good_item"
  local res_c = "ego:corrosion_resistance good_item"
  local prop_p = "randart artprops:rPois"
  local prop_c = "randart artprops:rCorr"
  local def = { { i = "cloak " .. res_p, w = 6 }, { i = "cloak " .. prop_p, w = 2 },
                { i = "cloak " .. res_c, w = 10 }, { i = "cloak " .. prop_c, w = 2 },
                { i = "pair of boots ego:flying good_item, " ..
                      "barding ego:flying good_item", w = 10 },
                { i = "kite shield " .. res_c, w = 8 },
                { i = "kite shield " .. prop_c, w = 2 },
                { i = "scale mail ego:resonance good_item", w = 4 },
                { i = "chain mail ego:resonance good_item", w = 6 },
                { i = "any ring " .. prop_p, w = 8 },
                { i = "any ring " .. prop_c, w = 12 },
                { i = "any ring randart artprops:Fly", w = 2 },
                { i = "amulet of chemistry randart", w = 15 }, }
  e.kitem("d = " .. n_weapon .. " / athame ego:draining w:4 / " ..
               "hand cannon good_item w:20")
  e.kitem("e = staff of alchemy randart artprops:Hexes w:5 / " ..
          "staff of alchemy randart artprops:Forge w:5 / " ..
          "randbook disc:" .. schools1 .. " disc2:" .. schools2 .. " " ..
          "splevels:33 numspells:5 / " ..
          "orb ego:attunement randart artprops:" .. orbprop .. " w:3 / " ..
          "orb ego:stardust randart artprops:" .. orbprop .. " w:3 / " ..
          "orb ego:guile randart artprops:" .. orbprop .. " w:2 / " ..
          "orb ego:glass randart artprops:" .. orbprop .. " w:2 / " ..
          "manual of alchemy w:5 / manual of forgecraft w:5")
  e.kitem("f = " .. util.random_weighted_from("w", def).i)
  e.kitem("g = maw talisman w:8 " .. prop_p .. " / maw talisman w:12 " .. prop_c .. " / " ..
              "eel talisman w:8 " .. prop_p .. " / eel talisman w:12 " .. prop_c .. " / " ..
              "fortress talisman randart w:20 / lupine talisman w:8 " .. prop_p .. " / " ..
              "lupine talisman w:12 " .. prop_c .. " / serpent talisman w:15 " .. prop_c .. " / " ..
              "spider talisman w:15 " .. prop_c .. " / wellspring talisman w:8 " .. prop_p .. " / " ..
              "wellspring talisman w:12 " .. prop_c .. " / blade talisman w:8 " .. prop_p .. " / " ..
              "blade talisman w:8 " .. prop_p .. " / dragon-coil talisman w:15" .. prop_c .. " / " ..
              "dragon-coil talisman w:15" .. prop_c .. " / hive talisman w:8 " .. prop_p .. " / " ..
              "hive talisman w:12 " .. prop_c .. " / riddle talisman w:8 " .. prop_p .. " / " ..
              "riddle talisman w:12 " .. prop_c .. " / sanguine talisman w:8 " .. prop_p .. " / " ..
              "sanguine talisman w:12 " .. prop_c)
  e.kitem("h = damaged broad axe ego:flaming pre_id no_pickup")
  e.kitem("i = damaged scimitar ego:flaming pre_id no_pickup")
  e.kitem("j = damaged glaive ego:flaming pre_id no_pickup")
  e.kitem("k = damaged quarterstaff ego:freezing pre_id no_pickup / " ..
              "damaged rapier ego:freezing pre_id no_pickup / " ..
              "damaged dire flail ego:freezing pre_id no_pickup")
  e.kitem("| = " .. n_weapon .. " / athame ego:draining w:4 / " ..
               "hand cannon good_item w:20 / " ..
               "randbook splevels:33 numspells:5 w:20 / " ..
               util.random_weighted_from("w", def).i .. " w:30 / " ..
               "swamp dragon scales randart w:30 / " ..
               "any aux armour randart w:14 / any control misc / " ..
               "any jewellery randart w:4 / any manual w:4")
  e.kitem("$ = $ no_pickup")
  e.kitem("% = any potion q:2")
  e.nsubst(item_nsubst .. " = 2:d / 2:e / 1:f / 2:g / *:|")
  e.nsubst("i = 1:h / 1:i / 1:j / 2 = hij / *:k")
  e.nsubst("$ = " .. potion_count - 1 .. " = %$$ / " .. potion_count.. ":% / *:$")
end

-- ############################################################################
-- # <<1>> Gulch layout subvault functions
-- ############################################################################
-- # Various different functions for crunching down the base Gulch layouts'
-- # subvault headers, one shared between each of them and then each layout's
-- # given variations on monster choices and terrain randomization.
-- ############################################################################
function gulch_generic_subvaults(e, subst_glyphs, subst_string, break_doors, trap_count)
  e.tags("allow_dup luniq unrand")
  e.subst("1 = .11122")
  if #subst_glyphs > 1 then
    for i, _ in pairs(subst_glyphs) do
      e.subst(subst_glyphs[i] .. " : " .. subst_string)
    end
  end
  if break_doors then
    e.kfeat("- = broken_door")
    e.nsubst("+ = 1:x / 1:+ / * = + -:3")
  end
  gulch_setup(e, false, trap_count)
end

function gulch_onslaught(e, is_subvault)
  e.kmons("1 : alligator / anaconda / large slime creature w:2 / " ..
              "crawling flesh cage w:12")
  e.kmons("2 = mongrel wurm / rusted inspector / roaming sludgefish w:4")
  e.kmons("3 = roaming sludgefish / fungal shambler")
  e.kmons("4 = great orb of eyes / crawling flesh cage")
  e.kmons("5 = fungal shambler / formless jellyfish / " ..
              "telencephalon w:4 / torpor snail w:1")
  if is_subvault and crawl.coinflip() then
    e.kmons("? = fungus")
    e.subst("? : ;WW?")
    e.subst("' = ;")
  else
    gulch_boss_theme_sets(e, false)
  end
  if is_subvault then
    e.tags("gulch_onslaught_subvault allow_dup luniq unrand")
    gulch_generic_subvaults(e, {"y", "Y", "z", "Z"}, "x`", false, "1")
  end
end

function gulch_crossways_sections(e)
  e.tags("gulch_crossways_sections")
  e.kmons("1 : alligator / tyrant leech w:8 / large slime creature w:2 / " ..
              "crawling flesh cage w:12")
  e.kmons("2 = mongrel wurm / rusted inspector w:12 / roaming sludgefish w:4")
  e.kmons("3 = roaming sludgefish / fungal shambler")
  e.kmons("4 = great orb of eyes / glowing orange brain w:2 / telencephalon w:2")
  e.kmons("5 = fungal shambler / formless jellyfish w:6 / " ..
              "telencephalon w:4 / torpor snail w:1")
  e.subst("~ = ..Wwx")
  gulch_boss_theme_sets(e, false)
  gulch_generic_subvaults(e, {"y", "z"}, "x.", true, "1")
  gulch_loot(e, "|", 4)
end

function gulch_network(e)
  e.tags("gulch_network")
  e.kmons("1 : alligator / anaconda w:8 / large slime creature w:2 / " ..
              "crawling flesh cage w:12")
  e.kmons("2 = mongrel wurm / rusted inspector w:12 / roaming sludgefish w:4")
  e.kmons("3 = roaming sludgefish / fungal shambler")
  e.kmons("4 = great orb of eyes / crawling flesh cage / telencephalon w:2")
  e.kmons("5 = fungal shambler / formless jellyfish w:6 / " ..
              "telencephalon w:4 / torpor snail w:1")
  gulch_boss_theme_sets(e, false)
  gulch_generic_subvaults(e, {"y", "z"}, "xxW..", true, "1")
  gulch_loot(e, "|", 4)
end

function gulch_chamber_river(e, is_subvault)
  e.orient("float")
  e.kmons("1 : alligator / tyrant leech w:8 / large slime creature w:2 / " ..
              "crawling flesh cage w:12")
  e.kmons("2 = mongrel wurm / rusted inspector w:12 / roaming sludgefish w:4")
  e.kmons("3 = roaming sludgefish / fungal shambler")
  e.kmons("4 = great orb of eyes / crawling flesh cage / telencephalon w:2")
  e.kmons("5 = fungal shambler / formless jellyfish w:6 / " ..
              "telencephalon w:4 / torpor snail w:1")
  if crawl.one_chance_in(3) then
    e.kmons("? = fungus")
    e.subst("? : ;WW?")
    e.subst("' = ?W;;")
  else
    gulch_boss_theme_sets(e, false)
  end
  if is_subvault then
    gulch_loot(e, "|", 3)
  end
  gulch_generic_subvaults(e, {"y", "z", "Y", "Z"}, "xxW..", true, "1")
end

function gulch_winding_coils(e)
  e.tags("gulch_coil")
  e.kmons("1 : alligator / anaconda w:8 / large slime creature w:2 / " ..
              "crawling flesh cage w:12")
  e.kmons("2 = mongrel wurm / rusted inspector w:12 / roaming sludgefish w:4")
  e.kmons("3 = roaming sludgefish / fungal shambler")
  e.kmons("4 = great orb of eyes / crawling flesh cage / telencephalon w:2")
  e.kmons("5 = fungal shambler / formless jellyfish w:6 / " ..
              "telencephalon w:4 / torpor snail w:1")
  if crawl.one_chance_in(4) then
    e.kmons("? = fungus")
    e.subst("? : ;WW?")
    e.subst("' = ;")
  else
    gulch_boss_theme_sets(e, false)
  end
  e.subst("~ = ..Wwx")
  gulch_generic_subvaults(e, {"y", "z"}, "xxW..", false, "1")
  gulch_loot(e, "|", 2)
end

function gulch_divide_sides(e)
  e.tags("gulch_divide_sides")
  e.kmons("1 : alligator / anaconda w:4 / large slime creature w:2 / " ..
              "crawling flesh cage")
  e.kmons("2 = mongrel wurm / rusted inspector w:12 / roaming sludgefish w:4")
  e.kmons("3 = roaming sludgefish / fungal shambler")
  e.kmons("4 = great orb of eyes / crawling flesh cage / telencephalon w:2")
  e.kmons("5 = fungal shambler / formless jellyfish w:6 / " ..
              "telencephalon w:4 / torpor snail w:1")
  gulch_boss_theme_sets(e, false)
  e.subst("~ = .Wwx")
  gulch_generic_subvaults(e, {"y", "z"}, "xw.", false, "2")
  gulch_loot(e, "|", 2)
end

function gulch_divide_center(e)
  e.tags("gulch_divide_center")
  e.kmons("1 : alligator / anaconda w:8 / large slime creature w:2 / " ..
              "crawling flesh cage w:12")
  e.kmons("2 = mongrel wurm / rusted inspector w:12 / roaming sludgefish w:4")
  e.kmons("3 = roaming sludgefish / fungal shambler")
  e.kmons("4 = great orb of eyes / crawling flesh cage / telencephalon w:2")
  gulch_boss_theme_sets(e, true)
  e.subst("~ = ..Wwx")
  gulch_generic_subvaults(e, {"y", "z"}, "xxW..", false, "1")
  gulch_loot(e, "|", 2)
end
}}

#############################################################################
# <<2>> Gulch entry vaults
#############################################################################
# Baseline rules:
# * Gulch entries should emphasize scrap or water and leave out mould.
# * All Gulch entry vaults should use normal Vaults spawns (outside of
#   rusted inspectors or the plainest Lair branch guest beasts), and
#   should have some minor floor scaling.
# * The gulch_portal(_G) function covers water recolouring and placement.
#   It also assigns clean shallow water to `y`, Gulch metal walls to `z`,
#   and the entrance feature on `O`.
#############################################################################

