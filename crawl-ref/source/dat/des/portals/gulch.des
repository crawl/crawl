########################################
# The Gulch network: enter one building, walk through maintenance tunnels
# and closets, arrive at at another building. One of the driest arrangements
# to help with it being both narrow and open at the same time.

NAME:     regret_index_gulch_network
WEIGHT:   25
: if crawl.one_chance_in(5) then
KMONS:    1 = mongrel wurm / alligator w:8 / crawling flesh cage w:14
KMONS:    2 = rusted inspector
KMONS:    3 = ironbound mechanist
KMONS:    4 = roaming sludgefish / telencephalon w:6
KMONS:    ? = stack of scrap
SUBST:    ' = ``?
: else
KMONS:    1 : alligator w:8 / anaconda / crawling flesh cage w:14
KMONS:    2 = mongrel wurm / rusted inspector
