########################################
# The Gulch Winding Coils: another small layout of cross tunnels and open
# subvault segments, notable for having different entrances than most other
# symmetrical subvaults.
NAME:     regret_index_gulch_winding_coils
WEIGHT:   25
: if crawl.one_chance_in(5) then
KMONS:    1 = alligator w:8 / crawling flesh cage w:14 / rusted inspector w:4
KMONS:    2 = mongrel wurm
KMONS:    3 = fire dragon draugr ; halberd ego:venom | battleaxe ego:venom
KMONS:    4 = fungal shambler / roaming sludgefish / telencephalon w:6
: else
KMONS:    1 : alligator w:8 / anaconda / crawling flesh cage w:14
KMONS:    2 = mongrel wurm / rusted inspector
KMONS:    3 = roaming sludgefish / great orb of eyes w:2
KMONS:    4 = fungal shambler / telencephalon w:4
: end
KMONS:    5 = fungal shambler / formless jellyfish w:6 / telencephalon w:4
KMONS:    s = fungus
KMONS:    S = stack of scrap
KFEAT:    sS = W
SUBST:    y : xxW., z : xxW., - = ++-., ~ = .:35 W:20 s:5 S:5 w:25 x:15
SUBVAULT: B : gulch_coil
SUBVAULT: C : gulch_coil
COLOUR:   sS = lightgreen
: gulch_boss_theme_sets(_G, false)
: gulch_loot(_G, "BC|", 2)
: gulch_setup(_G, true, "2")
