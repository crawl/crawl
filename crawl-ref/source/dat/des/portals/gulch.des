########################################
# The Gulch Crossways: a wetter layout with an immediate ambush. One of the
# nastiest ones for louder characters, since there's no real place to
# retreat to from all sides, but we've got other portals centered around the
# exact same conceit.

NAME:     regret_index_gulch_crossways
WEIGHT:   25
: if crawl.one_chance_in(5) then
KMONS:    1 = deathcap
KMONS:    2 = fungal shambler
KMONS:    3 = mongrel wurm / roaming sludgefish
KFEAT:    23 = mould_patch
: else
KMONS:    1 : alligator w:8 / tyrant leech / crawling flesh cage w:14
KMONS:    2 = mongrel wurm / rusted inspector / roaming sludgefish
KMONS:    3 = fungal shambler / telencephalon w:4 / great orb of eyes w:2
: end
KMONS:    s = fungus
KMONS:    S = stack of scrap
KFEAT:    sS = W
KFEAT:    M = mould_patch
SHUFFLE:  CD / EF / GH / IJ
SUBST:    C = M, D = s, EF = W, GHIJ = .
SUBST:    y : xxW., z : xxW., - = ++-., ~ = .:35 W:20 s:5 S:5 w:25 x:15
SUBVAULT: B : gulch_crossways_sections
COLOUR:   sS = lightgreen
: gulch_loot(_G, "|", 2)
: gulch_setup(_G, true, "1")
